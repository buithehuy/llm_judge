# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME="LLM-as-a-Judge Platform"
APP_VERSION="0.1.0"
DEBUG=True

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/llm_judge"

# ─── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY="dev-secret-key-change-in-production-please"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
